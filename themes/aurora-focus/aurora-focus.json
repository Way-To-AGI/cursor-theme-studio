      "caption": "Beauty in the margins"
    }
  },
  "copy": {
    "brandTitle": "Aurora Focus",
    "brandSubtitle": "Cursor Theme Studio",
    "signature": "Quiet light, clear mind",
    "tagline": "Quiet light, clear mind"
  },
  "baseTheme": {
    "mode": "dark",
    "accent": "#7EE7FF",
    "contrast": 178,
    "ink": "#F4F7FA",
    "surface": "#0A1018",
    "fonts": {
      "windowsCode": "Cascadia Code",
      "windowsUi": "Microsoft YaHei UI",
      "macCode": "SF Mono",
      "macUi": "PingFang SC"
