{
  "schemaVersion": 1,
  "engine": "cursor-theme-studio",
  "id": "aurora-focus",
  "displayName": "Aurora Focus",
  "version": "2.2.0",
  "css": "theme.css",
  "art": "background.png",
  "design": {
    "mode": "dark",
    "direction": "aurora-glass",
    "palette": {
      "accent": "#7EE7FF",
      "support": "#D7B48A",
      "surface": "#0A1018",
      "ink": "#F4F7FA"
    },
    "shape": {
      "radius": 20,
      "shadow": "soft"
    }
  },
  "background": {
    "source": "upload",
    "position": "78% 35%",
    "veil": 0.35,
    "prompt": "cinematic quiet aurora, teal and champagne light, deep ink negative space"
  },
  "decorations": {
    "density": "standard",
    "sidebarWidget": {
      "enabled": true,
      "icon": "A",
      "eyebrow": "AURORA",
